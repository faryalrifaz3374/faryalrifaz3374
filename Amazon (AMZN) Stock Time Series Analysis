art, end) in periods.items():\n    mask = (df_features.index >= start) & (df_features.index <= end)\n    period_data = df_features[mask]\n    \n    if len(period_data) > 0:\n        total_return = (period_data['Close'].iloc[-1] / period_data['Close'].iloc[0] - 1) * 100\n        annualized_return = ((period_data['Close'].iloc[-1] / period_data['Close'].iloc[0]) ** \n                            (252 / len(period_data)) - 1) * 100\n        volatility = period_data['Daily_Return'].std() * np.sqrt(252) * 100\n        sharpe = annualized_return / volatility if volatility > 0 else 0\n        max_dd = ((period_data['Close'] / period_data['Close'].cummax()) - 1).min() * 100\n        \n        period_metrics.append({\n            'Period': name,\n            'Total Return': total_return,\n            'Annualized Return': annualized_return,\n            'Volatility': volatility,\n            'Sharpe Ratio': sharpe,\n            'Max Drawdown': max_dd,\n            'Start Price': period_data['Close'].iloc[0],\n            'End Price': period_data['Close'].iloc[-1]\n        })\n\nmetrics_df = pd.DataFrame(period_metrics)\n\n# 1. Price Evolution by Period\nax1 = fig.add_subplot(gs[0, :])\ncolors = plt.cm.viridis(np.linspace(0, 1, len(periods)))\nfor i, (name, (start, end)) in enumerate(periods.items()):\n    mask = (df_features.index >= start) & (df_features.index <= end)\n    period_data = df_features[mask]\n    if len(period_data) > 0:\n        normalized = period_data['Close'] / period_data['Close'].iloc[0] * 100\n        ax1.plot(period_data.index, normalized, label=name, linewidth=2, color=colors[i])\nax1.set_title('Normalized Price Performance by Era (Base = 100)', fontsize=16, fontweight='bold')\nax1.set_xlabel('Year')\nax1.set_ylabel('Normalized Price')\nax1.legend(loc='upper left', fontsize=10)\nax1.grid(True, alpha=0.3)\nax1.set_yscale('log')\n\n# 2. Returns Comparison\nax2 = fig.add_subplot(gs[1, 0])\nx_pos = np.arange(len(metrics_df))\nbars = ax2.bar(x_pos, metrics_df