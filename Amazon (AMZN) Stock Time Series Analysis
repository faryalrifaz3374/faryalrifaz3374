 fontsize=14, fontweight='bold')\nax4.set_xlabel('Annualized Volatility (%)', fontsize=12)\nax4.set_ylabel('Annualized Return (%)', fontsize=12)\nax4.grid(True, alpha=0.3)\nax4.legend(fontsize=10)\n\n# Add colorbar\ncbar = plt.colorbar(scatter, ax=ax4)\ncbar.set_label('Year', fontsize=12)\n\nplt.tight_layout()\nplt.savefig('amazon_step4_volatility.png', dpi=300, bbox_inches='tight', facecolor='white')\nplt.show()\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"📊 INTERPRETATION: Volatility & Risk Analysis\")\nprint(\"=\" * 80)\nprint(f\"\"\"\n🔍 KEY INSIGHTS FROM VOLATILITY ANALYSIS:\n\n1. RETURN DISTRIBUTION CHARACTERISTICS:\n   • Mean Daily Return: {returns_clean.mean()*100:.3f}% (slightly positive drift)\n   • Volatility: {returns_clean.std()*100:.2f}% daily ({returns_clean.std()*np.sqrt(252)*100:.1f}% annualized)\n   • Skewness: {returns_clean.skew():.2f} (slightly left-skewed - more extreme negative days)\n   • Kurtosis: {returns_clean.kurtosis():.2f} (fat tails - more extreme events than normal)\n   • Worst single day: {returns_clean.min()*100:.2f}% (likely 2000 or 2008 crash)\n   • Best single day: {returns_clean.max()*100:.2f}% (likely post-crash recovery)\n\n2. VOLATILITY CLUSTERING:\n   • Clear evidence of volatility clustering - high volatility periods cluster together\n   • Major spikes during: Dot-com crash (2000-2002), Financial Crisis (2008), COVID (2020)\n   • Current volatility: Near historical lows - complacency risk?\n\n3. RISK-RETURN PROFILE:\n   • Average annual return: {yearly_stats['Annual_Return'].mean():.1f}%\n   • Average annual volatility: {yearly_stats['Annual_Volatility'].mean():.1f}%\n   • Average Sharpe Ratio: {yearly_stats['Sharpe_Ratio'].mean():.2f} (excellent risk-adjusted returns)\n   • Best risk-adjusted years: 2003, 2009, 2015 (high returns, moderate volatility)\n   • Worst risk-adjusted years: 2000, 2008, 2022 (negative returns, high volatility)\n\n4. RISK MANAGEMENT IMPLICATIONS:\n   • Amazon is a HIGH volatility stock - not for conserva