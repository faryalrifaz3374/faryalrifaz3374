                     -12.8770     0.000000     ✅ YES       \n================================================================================\n","output_type":"stream"}],"execution_count":8},{"cell_type":"markdown","source":"# =============================================================================\n# CELL 8: VISUALIZATION OF STATIONARITY TESTS\n# =============================================================================","metadata":{}},{"cell_type":"code","source":"\n\n\"\"\"\n## Step 5.1: Visualizing Stationarity Transformations 📈\n\nThis visualization demonstrates the effect of differencing on stationarity:\n- Top row: Original non-stationary series (trends visible)\n- Bottom row: Stationary transformations (mean-reverting behavior)\n\"\"\"\n\nfig, axes = plt.subplots(3, 2, figsize=(18, 16))\nfig.suptitle('Stationarity Analysis: Original vs Transformed Series', \n             fontsize=20, fontweight='bold', y=0.98)\n\n# 1. Raw Prices\nax1 = axes[0, 0]\nax1.plot(df_features.index, df_features['Close'], color='#1f77b4', linewidth=1.5)\nax1.set_title('1. Raw Closing Prices (NON-STATIONARY)', fontsize=14, fontweight='bold', color='red')\nax1.set_xlabel('Year')\nax1.set_ylabel('Price ($)')\nax1.grid(True, alpha=0.3)\n# Add trend line\nz = np.polyfit(range(len(df_features)), df_features['Close'], 1)\np = np.poly1d(z)\nax1.plot(df_features.index, p(range(len(df_features))), \"r--\", alpha=0.8, linewidth=2, label='Trend')\nax1.legend()\n\n# 2. First Differences\nax2 = axes[0, 1]\nax2.plot(df_features.index[1:], df_features['Close'].diff().dropna(), color='#2ca02c', linewidth=1, alpha=0.7)\nax2.axhline(y=0, color='black', linestyle='-', linewidth=1)\nax2.axhline(y=df_features['Close'].diff().mean(), color='red', linestyle='--', linewidth=2, label='Mean')\nax2.set_title('2. First Differences (STATIONARY)', fontsize=14, fontweight='bold', color='green')\nax2.set_xlabel('Year')\nax2.set_ylabel('Price Change ($)')\nax2.grid(True, alpha=0.3)\nax2.legend()\n\n# 3. Log Prices\nax3 = axes[1, 0]\nax3.plot(df_features.index, np.log(df_features['Close']), color='#ff7f0e', linewidth=1.5)\nax3.set_title('3. Log Prices (NON-STATIONARY)', fontsize=14, fontweight='bold', color='red')\nax3.set_xlabel('Year')\nax3.set_ylabel('Log Price')\nax3.grid(True, alpha=0.3)\n# Add trend line\nz_log = np.polyfit(range(len(df_features)), np.log(df_features['Close']), 1)\np_log = np.poly1d(z_log)\nax3.plot(df_features.index, p_log(range(len(df_features))), \"r--\", alpha=0.8, linewidth=2, label='Trend')\nax3.legend()\n\n# 4. Log Returns\nax4 = axes[1, 1]\nlog_returns = np.log(df_features['Close'] / df_features['Close'].shift(1)).dropna()\nax4.plot(df_features.index[1:], log_returns * 100, color='#2ca02c', linewidth=0.8, alpha=0.6)\nax4.axhline(y=0, color='black', linestyle='-', linewidth=1)\nax4.axhline(y=log_returns.mean() * 100, color='red', linestyle='--', linewidth=2, label='Mean')\nax4.set_title('4. Log Returns (STATIONARY)', fontsize=14, fontweight='bold', color='green')\nax4.set_xlabel('Year')\nax4.set_ylabel('Log Return (%)')\nax4.grid(True, alpha=0.3)\nax4.legend()\nax4.set_ylim(-25, 25)\n\n# 5. Rolling Mean and Std (Raw Prices)\nax5 = axes[2, 0]\nwindow = 252  # 1 year\nrolling_mean = df_features['Close'].rolling(window=window).mean()\nrolling_std = df_features['Close'].rolling(window=window).std()\nax5.plot(df_features.index, df_features['Close'], color='gray', alpha=0.5, label='Price')\nax5.plot(df_features.index, rolling_mean, color='red', linewidth=2, label=f'{window}-day Mean')\nax5.fill_between(df_features.index, rolling_mean - rolling_std, rolling_mean + rolling_std, \n                 alpha=0.2, color='red', label='±1 Std Dev')\nax5.set_title('5. Rolling Statistics: Raw Prices (Trending Mean)', fontsize=14, fontweight='bold', color='red')\nax5.set_xlabel('Year')\nax5.set_ylabel('Price ($)')\nax5.legend()\nax5.grid(True, alpha=0.3)\nax5.set_yscale('log')\n\n# 6. Rolling Mean and Std (Returns)\nax6 = axes[2, 1]\nreturns = df_features['Daily_Return'].dropna()\nrolling_mean_ret = returns.rolling(window=window).mean() * 100\nrolling_std_ret = returns.rolling(window=window).std() * 100\nax6.plot(returns.index, returns * 100, color='gray', alpha=0.3, linewidth=0.5)\nax6.plot(returns.index, rolling_mean_ret, color='red', linewidth=2, label=f'{window}-day Mean')\nax6.fill_between(returns.index, rolling_mean_ret - rolling_std_ret, rolling_mean_ret + rolling_std_ret, \n                 alpha=0.2, color='red', label='±1 Std Dev')\nax6.axhline(y=0, color='black', linestyle='-', linewidth=1)\nax6.set_title('6. Rolling Statistics: Returns (Stable Mean)', fontsize=14, fontweight='bold', color='green')\nax6.set_xlabel('Year')\nax6.set_ylabel('Daily Return (%)')\nax6.legend()\nax6.grid(True, alpha=0.3)\nax6.set_ylim(-10, 10)\n\nplt.tight_layout()\nplt.savefig('amazon_step5_stationarity.png', dpi=300, bbox_inches='tight', facecolor='white')\nplt.show()\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"📊 INTERPRETATION: Stationarity Analysis\")\nprint(\"=\" * 80)\nprint(\"\"\"\n🔍 KEY INSIGHTS FROM STATIONARITY TESTS:\n\n1. RAW PRICE SERIES (Non-Stationary):\n   • Clear upward trend over 26 years\n   • Mean and variance change over time\n   • ADF Statistic: Very negative but p-value > 0.05\n   • Unit root present - shocks have permanent effects\n   • NOT suitable for ARMA modeling directly\n\n2. FIRST DIFFERENCES (Stationary):\n   • Removing trend creates mean-reverting series\n   • Constant mean around zero\n   • ADF p-value < 0.05 - reject unit root\n   • Suitable for ARIMA modeling (I=1)\n\n3. LOG TRANSFORMATION:\n   • Stabilizes variance (heteroscedasticity reduction)\n   • Trend still present - remains non-stationary\n   • Useful for percentage-based analysis\n   • Often combined with differencing\n\n4. LOG RETURNS (Stationary):\n   • Most common transformation for financial time series\n   • Approximately normally distributed\n   • Constant mean and variance\n   • Suitable for GARCH, RiskMetrics, and other models\n\n5. ROLLING STATISTICS COMPARISON:\n   • Raw prices: Rolling mean trends upward (non-stationary)\n   • Returns: Rolling mean stable around zero (stationary)\n   • Visual confirmation of ADF test results\n\n6. MODELING IMPLICATIONS:\n   • Use ARIMA(1,1,1) or similar for price levels\n   • Use ARMA/GARCH for returns directly\n   • Differencing order d=1 sufficient for stationarity\n   • Log transformation recommended for variance stability\n\"\"\")\nprint(\"=\" * 80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T06:09:48.929686Z","iopub.execute_input":"2026-03-08T06:09:48.93002Z","iopub.status.idle":"2026-03-08T06:09:55.482429Z","shell.execute_reply.started":"2026-03-08T06:09:48.929993Z","shell.execute_reply":"2026-03-08T06:09:55.480859Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x1600 with 6 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n================================================================================\n📊 INTERPRETATION: Stationarity Analysis\n================================================================================\n\n🔍 KEY INSIGHTS FROM STATIONARITY TESTS:\n\n1. RAW PRICE SERIES (Non-Stationary):\n   • Clear upward trend over 26 years\n   • Mean and variance change over time\n   • ADF Statistic: Very negative but p-value > 0.05\n   • Unit root present - shocks have permanent effects\n   • NOT suitable for ARMA modeling directly\n\n2. FIRST DIFFERENCES (Stationary):\n   • Removing trend creates mean-reverting series\n   • Constant mean around zero\n   • ADF p-value < 0.05 - reject unit root\n   • Suitable for ARIMA modeling (I=1)\n\n3. LOG TRANSFORMATION:\n   • Stabilizes variance (heteroscedasticity reduction)\n   • Trend still present - remains non-stationary\n   • Useful for percentage-based analysis\n   • Often combined with differencing\n\n4. LOG RETURNS (Stationary):\n   • Most common transformation for financial time series\n   • Approximately normally distributed\n   • Constant mean and variance\n   • Suitable for GARCH, RiskMetrics, and other models\n\n5. ROLLING STATISTICS COMPARISON:\n   • Raw prices: Rolling mean trends upward (non-stationary)\n   • Returns: Rolling mean stable around zero (stationary)\n   • Visual confirmation of ADF test results\n\n6. MODELING IMPLICATIONS:\n   • Use ARIMA(1,1,1) or similar for price levels\n   • Use ARMA/GARCH for returns directly\n   • Differencing order d=1 sufficient for stationarity\n   • Log transformation recommended for variance stability\n\n================================================================================\n","output_type":"stream"}],"execution_count":9},{"cell_type":"markdown","source":"# =============================================================================\n# CELL 9: ACF AND PACF ANALYSIS\n# =============================================================================","metadata":{}},{"cell_type":"code","source":"\n\n\"\"\"\n## Step 5.2: Autocorrelation and Partial Autocorrelation Analysis 📊\n\nACF and PACF plots help identify:\n- AR (AutoRegressive) order from PACF\n- MA (Moving Average) order from ACF\n- Seasonality patterns\n- Differencing requirements\n\"\"\"\n\nfrom statsmodels.graphics.tsaplots import plot_acf, plot_pacf\n\nfig, axes = plt.subplots(2, 3, figsize=(18, 12))\nfig.suptitle('Autocorrelation Analysis: Identifying Time Series Structure', \n             fontsize=20, fontweight='bold', y=0.98)\n\n# 1. ACF of Raw Prices\nax1 = axes[0, 0]\nplot_acf(df_features['Close'].dropna(), lags=40, ax=ax1, title='ACF: Raw Prices')\nax1.grid(True, alpha=0.3)\n\n# 2. PACF of Raw Prices\nax2 = axes[0, 1]\nplot_pacf(df_features['Close'].dropna(), lags=40, ax=ax2, title='PACF: Raw Prices')\nax2.grid(True, alpha=0.3)\n\n# 3. First Differences ACF/PACF combined view\nax3 = axes[0, 2]\nprice_diff_clean = df_features['Close'].diff().dropna()\nplot_acf(price_diff_clean, lags=40, ax=ax3, title='ACF: First Differences')\nax3.grid(True, alpha=0.3)\n\n# 4. Returns ACF\nax4 = axes[1, 0]\nreturns_clean = df_features['Daily_Return'].dropna()\nplot_acf(returns_clean, lags=40, ax=ax4, title='ACF: Daily Returns')\nax4.grid(True, alpha=0.3)\n\n# 5. Returns PACF\nax5 = axes[1, 1]\nplot_pacf(returns_clean, lags=40, ax=ax5, title='PACF: Daily Returns')\nax5.grid(True, alpha=0.3)\n\n# 6. Squared Returns ACF (Volatility Clustering)\nax6 = axes[1, 2]\nsquared_returns = returns_clean ** 2\nplot_acf(squared_returns, lags=40, ax=ax6, title='ACF: Squared Returns (Volatility)')\nax6.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('amazon_step5_acf_pacf.png', dpi=300, bbox_inches='tight', facecolor='white')\nplt.show()\n\n# Calculate and display autocorrelation statistics\nprint(\"\\n\" + \"=\" * 80)\nprint(\"📊 AUTOCORRELATION ANALYSIS RESULTS\")\nprint(\"=\" * 80)\n\n# Raw prices autocorrelation\nfrom statsmodels.tsa.stattools import acf, pacf\nacf_price = acf(df_features['Close'].dropna(), nlags=5, fft=True)\nacf_returns = acf(returns_clean, nlags=5, fft=True)\nacf_squared = acf(squared_returns, nlags=5, fft=True)\n\nprint(\"\\n1. RAW PRICES AUTOCORRELATION:\")\nprint(f\"   Lag 1: {acf_price[1]:.4f} (Very high - strong trend)\")\nprint(f\"   Lag 5: {acf_price[5]:.4f}\")\nprint(f\"   Interpretation: Strong persistence, random walk behavior\")\n\nprint(\"\\n2. DAILY RETURNS AUTOCORRELATION:\")\nprint(f\"   Lag 1: {acf_returns[1]:.4f} (Weak - near zero)\")\nprint(f\"   Lag 5: {acf_returns[5]:.4f}\")\nprint(f\"   Interpretation: Weak linear dependence, efficient market\")\n\nprint(\"\\n3. SQUARED RETURNS AUTOCORRELATION (Volatility):\")\nprint(f\"   Lag 1: {acf_squared[1]:.4f} (Significant - volatility clustering)\")\nprint(f\"   Lag 5: {acf_squared[5]:.4f}\")\nprint(f\"   Interpretation: Strong volatility persistence - GARCH effects\")\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"📊 INTERPRETATION: ACF/PACF Analysis\")\nprint(\"=\" * 80)\nprint(\"\"\"\n🔍 KEY INSIGHTS FROM AUTOCORRELATION ANALYSIS:\n\n1. RAW PRICES:\n   • ACF decays very slowly (characteristic of random walk)\n   • PACF shows significant lag 1 (AR(1) structure)\n   • Confirms non-stationarity\n   • Requires differencing for modeling\n\n2. FIRST DIFFERENCES:\n   • ACF drops sharply after lag 0\n   • Weak autocorrelation at higher lags\n   • Some structure at lag 1 suggests MA(1) component\n   • Stationary series suitable for ARMA\n\n3. DAILY RETURNS:\n   • Very weak autocorrelation (market efficiency)\n   • No significant AR or MA structure\n   • Random walk hypothesis holds for returns\n   • Difficult to predict linearly\n\n4. SQUARED RETURNS (VOLATILITY):\n   • Significant autocorrelation in squared returns\n   • Slow decay indicates volatility clustering\n   • Strong evidence for GARCH/ARCH models\n   • Risk is predictable even if returns are not\n\n5. MODEL RECOMMENDATIONS:\n   • Returns: Random walk with drift (difficult to beat)\n   • Volatility: GARCH(1,1) or EGARCH for risk forecasting\n   • Price levels: ARIMA(0,1,0) or ARIMA(1,1,1)\n   • Long-term: Consider structural breaks and regime changes\n\"\"\")\nprint(\"=\" * 80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T06:09:55.48411Z","iopub.execute_input":"2026-03-08T06:09:55.48459Z","iopub.status.idle":"2026-03-08T06:09:59.043082Z","shell.execute_reply.started":"2026-03-08T06:09:55.484555Z","shell.execute_reply":"2026-03-08T06:09:59.041823Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x1200 with 6 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n================================================================================\n📊 AUTOCORRELATION ANALYSIS RESULTS\n================================================================================\n\n1. RAW PRICES AUTOCORRELATION:\n   Lag 1: 0.9990 (Very high - strong trend)\n   Lag 5: 0.9952\n   Interpretation: Strong persistence, random walk behavior\n\n2. DAILY RETURNS AUTOCORRELATION:\n   Lag 1: -0.0050 (Weak - near zero)\n   Lag 5: -0.0160\n   